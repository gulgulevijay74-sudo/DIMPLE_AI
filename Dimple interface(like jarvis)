<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>D.I.M.P.L · ORBIT CONTROL</title>
<style>
/* ── RESET & ROOT ─────────────────────────────────────── */
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
:root {
  --bg:     #011C2D;
  --panel:  rgba(1,18,36,0.84);
  --border: rgba(0,200,255,0.16);
  --cyan:   #64E6EF;
  --lcyan:  #B4F6FB;
  --dim:    rgba(100,230,239,0.36);
  --warn:   rgba(255,200,60,0.88);
}
html,body { width:100%; height:100%; overflow:hidden; }
body {
  background: var(--bg);
  font-family:'Courier New',monospace;
  color:#a0d8ef;
}

/* ── STARFIELD ─────────────────────────────────────────── */
body::before {
  content:''; position:fixed; inset:0; z-index:0; pointer-events:none;
  background-image:
    radial-gradient(1px 1px at  4%  6%, rgba(255,255,255,.50) 0%,transparent 100%),
    radial-gradient(1px 1px at 11% 19%, rgba(255,255,255,.32) 0%,transparent 100%),
    radial-gradient(1px 1px at 19% 44%, rgba(255,255,255,.26) 0%,transparent 100%),
    radial-gradient(1px 1px at 29%  8%, rgba(255,255,255,.38) 0%,transparent 100%),
    radial-gradient(1px 1px at 37% 62%, rgba(255,255,255,.22) 0%,transparent 100%),
    radial-gradient(1px 1px at 48% 30%, rgba(255,255,255,.30) 0%,transparent 100%),
    radial-gradient(1px 1px at 57% 77%, rgba(255,255,255,.24) 0%,transparent 100%),
    radial-gradient(1px 1px at 66% 14%, rgba(255,255,255,.40) 0%,transparent 100%),
    radial-gradient(1px 1px at 75% 52%, rgba(255,255,255,.28) 0%,transparent 100%),
    radial-gradient(1px 1px at 84% 88%, rgba(255,255,255,.32) 0%,transparent 100%),
    radial-gradient(1px 1px at 93% 35%, rgba(255,255,255,.36) 0%,transparent 100%),
    radial-gradient(1px 1px at 22% 72%, rgba(255,255,255,.28) 0%,transparent 100%),
    radial-gradient(1px 1px at 43% 91%, rgba(255,255,255,.22) 0%,transparent 100%),
    radial-gradient(1.5px 1.5px at 53% 48%, rgba(180,246,251,.40) 0%,transparent 100%),
    radial-gradient(1.5px 1.5px at 78% 22%, rgba(180,246,251,.30) 0%,transparent 100%),
    radial-gradient(1.5px 1.5px at 88%  4%, rgba(255,255,255,.34) 0%,transparent 100%),
    radial-gradient(2px   2px   at 33% 55%, rgba(180,246,251,.22) 0%,transparent 100%),
    radial-gradient(1px 1px at 60% 95%, rgba(255,255,255,.20) 0%,transparent 100%);
}

/* ── DESKTOP GRID ──────────────────────────────────────── */
.desktop {
  position:relative; z-index:1;
  width:100vw; height:100vh;
  display:grid;
  grid-template-columns: clamp(280px, 22vw, 420px) 1fr clamp(280px, 22vw, 420px);
  grid-template-rows:1fr;
  padding: clamp(16px, 1.6vw, 28px);
  gap: clamp(12px, 1.2vw, 20px);
}

/* ── SHARED PANEL ──────────────────────────────────────── */
.panel {
  border:1px solid var(--border);
  border-radius: clamp(8px,0.8vw,14px);
  background:var(--panel);
  backdrop-filter:blur(10px);
  position:relative;
  overflow:hidden;
}
.panel::after {
  content:''; position:absolute; inset:0; border-radius: inherit; pointer-events:none;
  box-shadow:inset 0 0 50px rgba(0,60,140,.12);
}
.panel::before {
  content:''; position:absolute; z-index:2;
  top:8px; left:8px; width:clamp(12px,1.2vw,18px); height:clamp(12px,1.2vw,18px);
  border-top:1.5px solid var(--cyan); border-left:1.5px solid var(--cyan);
  pointer-events:none;
}
.panel-label {
  position:absolute; top:clamp(12px,1.2vw,18px); left:clamp(18px,1.8vw,26px);
  font-size: clamp(9px,0.75vw,13px); letter-spacing:.22em; text-transform:uppercase;
  color:var(--dim);
}

/* ── LEFT PANEL ───────────────────────────────────────── */
.panel-left { display:flex; flex-direction:column; padding: clamp(40px,5vh,70px) clamp(14px,1.4vw,22px) clamp(14px,1.4vw,22px); gap: clamp(8px,0.9vh,14px); }
.stat-row {
  display:flex; justify-content:space-between; align-items:center;
  padding: clamp(6px,0.7vh,11px) clamp(10px,1vw,16px);
  border:1px solid rgba(0,160,255,.12); border-radius:5px;
  background:rgba(0,40,100,.12);
}
.stat-row .k { font-size: clamp(9px,0.75vw,13px); letter-spacing:.13em; color:rgba(100,180,220,.55); text-transform:uppercase; }
.stat-row .v { font-size: clamp(11px,0.95vw,16px); color:var(--lcyan); font-weight:bold; }
.bar-wrap { width:100%; height: clamp(2px,0.25vh,4px); background:rgba(0,60,120,.35); border-radius:2px; overflow:hidden; }
.bar-fill { height:100%; border-radius:2px;
  background:linear-gradient(90deg,rgba(0,160,255,.55),var(--lcyan));
  animation:pb 3s ease-in-out infinite alternate; }
@keyframes pb { from{opacity:.5} to{opacity:1} }
.divider { border:none; border-top:1px solid rgba(0,100,180,.14); margin: clamp(3px,0.4vh,6px) 0; }
.dl { font-size: clamp(9px,0.72vw,12px); letter-spacing:.11em; color:rgba(0,200,255,.38);
  border-bottom:1px solid rgba(0,100,180,.10); padding-bottom: clamp(4px,0.5vh,8px);
  display:flex; justify-content:space-between; }
.dl .v { color:rgba(0,230,255,.75); }

/* ── CENTRE PANEL ──────────────────────────────────────── */
.panel-centre {
  display:flex; flex-direction:column; align-items:center; justify-content:flex-start;
  padding: clamp(48px,6vh,80px) clamp(20px,2vw,36px) clamp(18px,2vh,30px); gap: clamp(14px,1.8vh,26px); position:relative;
}
.grid-lines {
  position:absolute; inset:0; pointer-events:none;
  background-image:
    linear-gradient(rgba(0,100,180,.05) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,100,180,.05) 1px,transparent 1px);
  background-size: clamp(32px,3.5vw,55px) clamp(32px,3.5vw,55px);
}
.scan {
  position:absolute; left:0; right:0; height:1px; pointer-events:none;
  background:linear-gradient(90deg,transparent,rgba(0,200,255,.15),transparent);
  animation:scanAnim 6s linear infinite;
}
@keyframes scanAnim { 0%{top:0%} 100%{top:100%} }
.centre-head { font-size: clamp(10px,0.85vw,15px); letter-spacing:.30em; text-transform:uppercase; color:rgba(0,200,255,.50); }
.dimpl-wrap { display:flex; flex-direction:column; align-items:center; gap: clamp(4px,0.5vh,8px); }
.dimpl-wrap h2 {
  font-size: clamp(14px,1.4vw,24px); letter-spacing:.35em; text-transform:uppercase;
  color:var(--lcyan); text-shadow:0 0 18px rgba(180,246,251,.65);
}
#jarvis-like { filter:drop-shadow(0 0 16px rgba(100,230,239,.55)); }
.status-grid { display:grid; grid-template-columns:1fr 1fr; gap: clamp(6px,0.7vw,12px); width:100%; max-width: clamp(300px,32vw,520px); }
.s-cell {
  display:flex; flex-direction:column; align-items:center; padding: clamp(6px,0.8vh,12px) clamp(10px,1vw,16px);
  border:1px solid rgba(0,200,255,.12); border-radius:5px;
  background:rgba(0,40,100,.12);
}
.s-cell .sk { font-size: clamp(8px,0.65vw,11px); letter-spacing:.15em; color:rgba(0,200,255,.42); text-transform:uppercase; }
.s-cell .sv { font-size: clamp(10px,0.9vw,16px); color:var(--lcyan); font-weight:bold; margin-top:2px; }
.dot { width: clamp(5px,0.5vw,8px); height: clamp(5px,0.5vw,8px); border-radius:50%;background:rgba(0,230,140,.9);
  box-shadow:0 0 6px rgba(0,230,140,.7); animation:blink 2s ease-in-out infinite;
  display:inline-block; margin-right:5px; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.20} }

/* ── RIGHT PANEL ───────────────────────────────────────── */
.panel-right { display:flex; flex-direction:column; padding: clamp(40px,5vh,70px) clamp(14px,1.4vw,22px) clamp(14px,1.4vw,22px); gap: clamp(7px,0.8vh,13px); }
.log-entry { display:flex; flex-direction:column; gap:2px; border-bottom:1px solid rgba(0,100,180,.10); padding-bottom: clamp(5px,0.6vh,10px); }
.log-time  { font-size: clamp(8px,0.65vw,11px); letter-spacing:.10em; color:rgba(0,200,255,.32); }
.log-msg   { font-size: clamp(9px,0.75vw,13px); letter-spacing:.10em; color:rgba(0,220,255,.72); }
.log-warn  { color:var(--warn) !important; }
.mini-chart { width:100%; height: clamp(44px,5.5vh,80px); margin-top:auto; }
.mini-chart svg { width:100%; height:100%; }

/* ══ EARTH WIDGET — top-right ══ */
.earth-widget {
  position:fixed; top: clamp(16px,1.6vw,28px); right: clamp(16px,1.6vw,28px); z-index:9999;
  width: clamp(280px,22vw,420px); height: clamp(280px,22vw,420px);
  border:1px solid rgba(0,190,255,.38);
  border-radius: clamp(8px,0.8vw,14px);
  background: #000;
  display:flex; flex-direction:column; align-items:center; justify-content:center; gap: clamp(8px,0.9vw,14px);
  box-shadow:0 0 50px rgba(0,100,220,.28), inset 0 0 30px rgba(0,50,140,.18);
  overflow:hidden;
  transform-style: preserve-3d;
  perspective: 600px;
}
.tick { position:absolute; width: clamp(11px,1.1vw,18px); height: clamp(11px,1.1vw,18px); border-color:rgba(0,210,255,.65); border-style:solid; z-index:10; }
.tl{top:5px;left:5px;    border-width:2px 0 0 2px;}
.tr{top:5px;right:5px;   border-width:2px 2px 0 0;}
.bl{bottom:5px;left:5px; border-width:0 0 2px 2px;}
.br{bottom:5px;right:5px;border-width:0 2px 2px 0;}
.w-label { font-size: clamp(8px,0.7vw,12px); letter-spacing:.22em; text-transform:uppercase; color:rgba(0,200,255,.52); position:relative; z-index:10; }

/* ── Earth scene container ── */
.earth-scene {
  position:relative;
  width: clamp(210px,16.5vw,315px);
  height: clamp(210px,16.5vw,315px);
  transform-style: preserve-3d;
  perspective: 600px;
  flex-shrink:0;
}

/* ── Spinning rings around the scene ── */
.earth-rings-wrap {
  position:relative;
  width: clamp(210px,16.5vw,315px);
  height: clamp(210px,16.5vw,315px);
  display:flex; align-items:center; justify-content:center;
  transform-style: preserve-3d;
}
.ring { position:absolute; border-radius:50%; border-style:solid; border-color:transparent; top:50%; left:50%; transform:translate(-50%,-50%); }
.ring1 { width:calc(clamp(210px,16.5vw,315px) + 28px); height:calc(clamp(210px,16.5vw,315px) + 28px); border:1.5px solid transparent; border-top-color:rgba(0,220,255,.84); border-right-color:rgba(0,200,255,.36); animation:spinR 2.6s linear infinite; }
.ring2 { width:calc(clamp(210px,16.5vw,315px) + 46px); height:calc(clamp(210px,16.5vw,315px) + 46px); border:1px dashed rgba(0,160,255,.24); animation:spinR 5.5s linear infinite reverse; }
.ring3 { width:calc(clamp(210px,16.5vw,315px) + 62px); height:calc(clamp(210px,16.5vw,315px) + 62px); border:1px solid rgba(0,120,200,.10); }
@keyframes spinR { to{transform:translate(-50%,-50%) rotate(360deg)} }

/* ── EARTH + MOON (from original codepen, adapted) ── */
/* timing variables as plain CSS */
:root {
  --earthSpinDur: 3s;
  --moonOrbitDur: 81.966s; /* 3s * 27.322 */
  --moonSpinDur:  81s;     /* 3s * 27 */
}

.ew-earth, .ew-moon {
  border-radius: 50%;
  overflow: hidden;
  z-index: 0;
}
.ew-earth, .ew-earth::before, .ew-earth::after,
.ew-moon,  .ew-moon::before,  .ew-moon::after {
  position: absolute;
}
.ew-earth::before, .ew-earth::after,
.ew-moon::before,  .ew-moon::after {
  content: "";
  display: block;
  position: absolute;
  height: 100%;
}
.ew-earth::before, .ew-moon::before {
  border-radius: inherit;
  width: 100%;
  z-index: -1;
}
.ew-earth::after, .ew-moon::after {
  background-size: auto 100%;
  background-repeat: repeat-x;
  width: 400%;
  z-index: -2;
}

/* Earth */
.ew-earth {
  top: 50%; left: 50%;
  width: clamp(110px,8.5vw,160px);
  height: clamp(110px,8.5vw,160px);
  transform: translate(-50%,-50%);
  will-change: transform;
}
.ew-earth::before {
  background-image:
    radial-gradient(100% 125% at 40% 50%, rgba(0,0,0,0) 40%, rgb(0,0,0) 50%),
    radial-gradient(100% 100% at center, rgba(40,120,240,0) 47%, rgba(40,120,240,0.5) 48.5%, rgb(194,228,250) 50%);
}
.ew-earth::after {
  animation: ewTextureSpin var(--earthSpinDur) linear infinite;
  background-image: url("https://assets.codepen.io/416221/earth-texture.jpg");
}

/* Moon hitbox + moon */
.moon-hitbox {
  animation: ewMoonOrbitZ var(--moonOrbitDur) calc(var(--moonOrbitDur) * -0.25) ease-in-out infinite;
  position: absolute;
  top: 50%; left: 50%;
  transform: translateZ(0);
  width: clamp(28px,2.2vw,42px);
  height: clamp(28px,2.2vw,42px);
  margin-top: calc(clamp(28px,2.2vw,42px) * -0.5);
  margin-left: calc(clamp(28px,2.2vw,42px) * -0.5);
}
.ew-moon {
  animation: ewMoonOrbitX var(--moonOrbitDur) ease-in-out infinite;
  width: 100%;
  height: 100%;
  transform: translateZ(0) translateX(calc(clamp(110px,8.5vw,160px) * -0.7));
}
.ew-moon::before {
  background-image: radial-gradient(100% 125% at 40% 50%, rgba(0,0,0,0) 40%, rgb(0,0,0) 50%);
  box-shadow: 0 0 0.5em inset;
}
.ew-moon::after {
  animation: ewTextureSpin var(--moonSpinDur) linear infinite reverse;
  background-image: url("https://assets.codepen.io/416221/moon-texture.jpg");
}

@keyframes ewTextureSpin {
  from { transform: translateX(0) }
  to   { transform: translateX(-50%) }
}
@keyframes ewMoonOrbitX {
  from    { transform: translateZ(0)    translateX(calc(clamp(110px,8.5vw,160px) * -0.7)) }
  50%     { transform: translateZ(0)    translateX(calc(clamp(110px,8.5vw,160px) *  0.7)) }
  50.01%  { transform: translateZ(-1px) translateX(calc(clamp(110px,8.5vw,160px) *  0.7)) }
  to      { transform: translateZ(-1px) translateX(calc(clamp(110px,8.5vw,160px) * -0.7)) }
}
@keyframes ewMoonOrbitZ {
  from, to { transform: translateZ(calc(clamp(110px,8.5vw,160px) * -0.7)) }
  50%      { transform: translateZ(calc(clamp(110px,8.5vw,160px) *  0.7)) }
}

/* ══════════════════════════════════════════════════════════
   CHAT WIDGET — bottom-right, fluid desktop sizing
   ══════════════════════════════════════════════════════════ */
.chat-widget {
  position:fixed; bottom: clamp(16px,1.6vw,28px); right: clamp(16px,1.6vw,28px); z-index:9999;
  width: clamp(280px,22vw,420px); height: clamp(340px,36vh,520px);
  border:1px solid rgba(0,200,255,.26);
  border-radius: clamp(8px,0.8vw,14px);
  background:rgba(1,12,28,.93);
  backdrop-filter:blur(12px);
  display:flex; flex-direction:column;
  box-shadow:0 0 40px rgba(0,80,200,.22), inset 0 0 28px rgba(0,30,80,.18);
  overflow:hidden;
}
.chat-widget .tick { position:absolute; width: clamp(10px,1vw,16px); height: clamp(10px,1vw,16px); border-color:rgba(0,210,255,.54); border-style:solid; z-index:3; }
.chat-widget .tl{top:5px;left:5px;    border-width:2px 0 0 2px;}
.chat-widget .tr{top:5px;right:5px;   border-width:2px 2px 0 0;}
.chat-widget .bl{bottom:5px;left:5px; border-width:0 0 2px 2px;}
.chat-widget .br{bottom:5px;right:5px;border-width:0 2px 2px 0;}
.chat-header {
  padding: clamp(10px,1.2vh,18px) clamp(14px,1.4vw,22px) clamp(8px,1vh,14px);
  border-bottom:1px solid rgba(0,200,255,.12);
  display:flex; align-items:center; gap: clamp(7px,0.7vw,12px); flex-shrink:0;
}
.chat-header-dot { width: clamp(7px,0.65vw,10px); height: clamp(7px,0.65vw,10px); border-radius:50%; background:rgba(0,230,140,.9);
  box-shadow:0 0 8px rgba(0,230,140,.72); animation:blink 2s ease-in-out infinite; flex-shrink:0; }
.chat-header-title { font-size: clamp(9px,0.75vw,13px); letter-spacing:.22em; text-transform:uppercase; color:rgba(0,200,255,.62); }
.chat-messages {
  flex:1; overflow-y:auto; padding: clamp(10px,1.2vh,18px) clamp(12px,1.2vw,20px); display:flex; flex-direction:column; gap: clamp(7px,0.9vh,14px);
  scrollbar-width:thin; scrollbar-color:rgba(0,180,255,.20) transparent;
}
.chat-messages::-webkit-scrollbar { width:3px; }
.chat-messages::-webkit-scrollbar-thumb { background:rgba(0,180,255,.25); border-radius:2px; }
.chat-msg { display:flex; flex-direction:column; gap:3px; max-width:88%; }
.chat-msg.user { align-self:flex-end; align-items:flex-end; }
.chat-msg.bot  { align-self:flex-start; align-items:flex-start; }
.chat-bubble {
  padding: clamp(6px,0.8vh,11px) clamp(10px,1vw,16px); border-radius: clamp(5px,0.6vw,9px); font-size: clamp(10px,0.85vw,14px); line-height:1.5;
  letter-spacing:.04em; word-break:break-word;
}
.chat-msg.user .chat-bubble { background:rgba(0,100,200,.28); border:1px solid rgba(0,180,255,.22); color:rgba(180,246,251,.92); }
.chat-msg.bot  .chat-bubble { background:rgba(0,40,80,.38); border:1px solid rgba(0,160,200,.16); color:rgba(100,230,239,.88); }
.chat-msg .chat-time { font-size: clamp(7px,0.6vw,10px); color:rgba(0,180,255,.32); letter-spacing:.08em; }
.chat-input-row {
  padding: clamp(8px,1vh,14px) clamp(10px,1vw,16px); border-top:1px solid rgba(0,200,255,.12);
  display:flex; gap: clamp(6px,0.7vw,10px); align-items:center; flex-shrink:0;
}
.chat-input {
  flex:1; background:rgba(0,30,70,.42); border:1px solid rgba(0,180,255,.20);
  border-radius:5px; padding: clamp(5px,0.7vh,10px) clamp(10px,1vw,16px); font-size: clamp(10px,0.85vw,14px); font-family:'Courier New',monospace;
  color:rgba(180,246,251,.88); outline:none; letter-spacing:.06em; caret-color:rgba(0,220,255,.82);
}
.chat-input::placeholder { color:rgba(0,180,255,.30); }
.chat-input:focus { border-color:rgba(0,200,255,.44); box-shadow:0 0 10px rgba(0,180,255,.14); }
.chat-send {
  width: clamp(28px,2.6vw,40px); height: clamp(28px,2.6vw,40px); border-radius:5px; flex-shrink:0; cursor:pointer;
  background:rgba(0,100,200,.32); border:1px solid rgba(0,180,255,.28);
  display:flex; align-items:center; justify-content:center;
  transition:background .2s, box-shadow .2s;
}
.chat-send:hover { background:rgba(0,140,240,.44); box-shadow:0 0 14px rgba(0,180,255,.30); }
.chat-send svg { width: clamp(12px,1.1vw,18px); height: clamp(12px,1.1vw,18px); stroke:rgba(100,230,239,.88); fill:none; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; }
.chat-icon-btn {
  width: clamp(28px,2.6vw,40px); height: clamp(28px,2.6vw,40px); border-radius:5px; flex-shrink:0; cursor:pointer;
  background:rgba(0,40,80,.38); border:1px solid rgba(0,160,255,.22);
  display:flex; align-items:center; justify-content:center;
  transition:background .2s, box-shadow .2s, border-color .2s;
  color: rgba(100,230,239,.80);
}
.chat-icon-btn:hover { background:rgba(0,80,160,.44); box-shadow:0 0 12px rgba(0,180,255,.25); border-color:rgba(0,200,255,.44); }
.chat-icon-btn svg { width: clamp(12px,1.1vw,17px); height: clamp(12px,1.1vw,17px); }
.chat-icon-btn.active { background:rgba(255,40,40,.22); border-color:rgba(255,80,80,.55); color:rgba(255,140,140,.9); box-shadow:0 0 14px rgba(255,60,60,.30); animation:micPulse 0.8s ease-in-out infinite; }
@keyframes micPulse { 0%,100%{box-shadow:0 0 8px rgba(255,60,60,.30)} 50%{box-shadow:0 0 20px rgba(255,80,80,.60)} }

/* ══════════════════════════════════════════════════════════
   THREE.JS SPHERE WIDGET — bottom-left, fluid desktop sizing
   ══════════════════════════════════════════════════════════ */
.sphere-widget {
  position:fixed; bottom: clamp(16px,1.6vw,28px); left: clamp(16px,1.6vw,28px); z-index:9999;
  width: clamp(280px,22vw,420px); height: clamp(280px,22vw,420px);
  border:1px solid rgba(0,190,255,.30);
  border-radius: clamp(8px,0.8vw,14px);
  background:rgba(0,5,18,0.65);
  overflow:hidden;
  box-shadow:0 0 60px rgba(0,100,255,.30), inset 0 0 34px rgba(0,40,120,.34);
}
.sphere-widget .tick { position:absolute; width: clamp(11px,1.1vw,18px); height: clamp(11px,1.1vw,18px); border-color:rgba(0,210,255,.60); border-style:solid; z-index:2; }
.sphere-widget .tl{top:5px;left:5px;    border-width:2px 0 0 2px;}
.sphere-widget .tr{top:5px;right:5px;   border-width:2px 2px 0 0;}
.sphere-widget .bl{bottom:5px;left:5px; border-width:0 0 2px 2px;}
.sphere-widget .br{bottom:5px;right:5px;border-width:0 2px 2px 0;}
.sphere-widget .sw-label {
  position:absolute; bottom: clamp(8px,1vh,14px); left:0; right:0; text-align:center; z-index:2;
  font-size: clamp(8px,0.68vw,12px); letter-spacing:.22em; text-transform:uppercase;
  color:rgba(127,219,255,.74); pointer-events:none;
  text-shadow:0 0 10px rgba(0,200,255,.60);
}
.sphere-widget::before {
  content:''; position:absolute; inset:0; z-index:1; pointer-events:none; border-radius: inherit;
  background: radial-gradient(ellipse at center, rgba(0,80,200,0.18) 0%, rgba(0,20,60,0.40) 60%, transparent 100%);
}
#sphereContainer { width:100%; height:100%; }

/* chat box */
#chatBox {
  position:fixed; bottom: calc(clamp(280px,22vw,420px) + clamp(16px,1.6vw,28px) + 12px); left: clamp(16px,1.6vw,28px); z-index:10000;
  max-width: clamp(280px,22vw,420px);
  pointer-events:none;
  font-family:'Segoe UI',sans-serif;
  font-size: clamp(11px,0.95vw,16px); font-weight:500;
  background-image:linear-gradient(90deg,#7FDBFF,#C0C0C0,#7FDBFF);
  background-size:300% 100%;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text; color:transparent;
  opacity:0; white-space:pre-wrap;
  animation:gradientShift 4s linear infinite;
  transition:opacity 0.5s ease;
  text-shadow:none;
}
/* ── USER PHOTO ───────────────────────────────────────── */
.user-photo-wrap {
  display:flex; flex-direction:column; align-items:center; gap: clamp(6px,0.7vh,10px);
  margin: clamp(6px,0.8vh,12px) 0;
}
.user-photo {
  width: clamp(80px,7vw,120px); height: clamp(80px,7vw,120px);
  border-radius:50%;
  object-fit:cover;
  border:2px solid rgba(0,200,255,.45);
  box-shadow: 0 0 18px rgba(0,150,255,.50), 0 0 36px rgba(0,80,200,.25);
  display:block;
}
.user-photo-label {
  font-size: clamp(8px,0.65vw,11px); letter-spacing:.22em; text-transform:uppercase;
  color:rgba(0,200,255,.50);
}

/* ══════════════════════════════════════════════════════
   FLOATING BUBBLE LAUNCHER
   ══════════════════════════════════════════════════════ */
#dimpl-bubble {
  position: fixed;
  width: 56px; height: 56px;
  border-radius: 50%;
  background: radial-gradient(circle at 38% 38%, #011830, #000d1a);
  box-shadow: 0 0 18px rgba(0,200,255,0.55), 0 0 40px rgba(0,100,200,0.28), inset 0 0 14px rgba(0,50,120,0.40);
  cursor: pointer;
  z-index: 999999;
  display: flex; flex-direction:column; align-items:center; justify-content:center;
  user-select:none;
  transition: box-shadow 0.3s, transform 0.2s;
  border: 1px solid rgba(0,200,255,0.35);
  bottom: 28px; right: 28px;
}
#dimpl-bubble:hover {
  box-shadow: 0 0 28px rgba(0,220,255,0.80), 0 0 60px rgba(0,140,255,0.38);
  transform: scale(1.10);
}
#dimpl-bubble.dragging { cursor: grabbing; transform: scale(1.14); }
#bubble-svg { width: 48px; height: 48px; pointer-events:none; }
#bubble-label { display: none; }
#dimpl-app {
  position: fixed; inset: 0; z-index: 99998;
}
#dimpl-app.dimpl-open {
  /* kept for legacy compat */
}
#dimpl-close {
  position: fixed; top: 18px; right: 24px; z-index: 999999;
  width: 36px; height: 36px; border-radius: 50%;
  background: rgba(0,10,28,0.80); border: 1px solid rgba(0,200,255,0.30);
  align-items:center; justify-content:center;
  font-size: 16px; color: rgba(0,220,255,0.72); cursor:pointer;
  transition: background .2s, box-shadow .2s;
  box-shadow: 0 0 14px rgba(0,150,255,.22);
}
#dimpl-close:hover {
  background: rgba(180,0,0,0.28); border-color:rgba(255,80,80,.45);
  color:rgba(255,160,160,.9); box-shadow:0 0 18px rgba(255,50,50,.30);
}
#dimpl-bubble.ai-active { animation: bubbleIdle 2.5s ease-in-out infinite; }
@keyframes bubbleIdle {
  0%,100% { box-shadow: 0 0 22px rgba(0,200,255,0.55), 0 0 50px rgba(0,100,200,0.28), inset 0 0 18px rgba(0,50,120,0.40); }
  50%      { box-shadow: 0 0 42px rgba(0,240,255,0.85), 0 0 90px rgba(0,170,255,0.45), inset 0 0 22px rgba(0,80,180,0.50); }
}
/* ── Hide entire app until opened ── */
/* Fixed-position children escape overflow/visibility of parent,
   so we control them via a body class instead */
.earth-widget,
.sphere-widget,
.chat-widget,
#cameraModal,
#chatBox,
.desktop,
#dimpl-app,
#dimpl-close {
  display: none !important;
}
body.dimpl-open .earth-widget,
body.dimpl-open .sphere-widget,
body.dimpl-open .chat-widget,
body.dimpl-open #chatBox,
body.dimpl-open #dimpl-close {
  display: flex !important;
}
body.dimpl-open #cameraModal {
  /* camera modal shown via JS inline style when camera button clicked */
  /* do not set display here — JS controls it */
}
body.dimpl-open .desktop {
  display: grid !important;
}
body.dimpl-open #dimpl-app {
  display: block !important;
}

/* ════════════════════════════════════════════════════════
   SECURITY LOCK SCREEN
   ════════════════════════════════════════════════════════ */
#dimpl-lock {
  position: fixed; inset: 0; z-index: 9999999;
  background: #000d1a;
  display: none;          /* hidden by default — shown by JS on bubble click */
  align-items: center; justify-content: center;
  flex-direction: column;
  font-family: 'Courier New', monospace;
  overflow: hidden;
}
#dimpl-lock.lock-visible {
  display: flex !important;
  animation: lockFadeIn 0.35s cubic-bezier(.2,0,.2,1) forwards;
}
#dimpl-lock.lock-hidden {
  animation: lockFadeOut 0.45s cubic-bezier(.4,0,.2,1) forwards;
  pointer-events: none;
}
@keyframes lockFadeIn  { from{opacity:0;transform:scale(.97)} to{opacity:1;transform:scale(1)} }
@keyframes lockFadeOut { from{opacity:1;transform:scale(1)}   to{opacity:0;transform:scale(1.03)} }

/* starfield on lock screen */
#dimpl-lock::before {
  content:''; position:absolute; inset:0; pointer-events:none;
  background-image:
    radial-gradient(1px 1px at  8% 12%, rgba(255,255,255,.45) 0%,transparent 100%),
    radial-gradient(1px 1px at 20% 45%, rgba(255,255,255,.28) 0%,transparent 100%),
    radial-gradient(1px 1px at 34%  7%, rgba(255,255,255,.35) 0%,transparent 100%),
    radial-gradient(1px 1px at 55% 70%, rgba(255,255,255,.22) 0%,transparent 100%),
    radial-gradient(1px 1px at 70% 25%, rgba(180,246,251,.38) 0%,transparent 100%),
    radial-gradient(1px 1px at 82% 58%, rgba(255,255,255,.30) 0%,transparent 100%),
    radial-gradient(1px 1px at 91% 88%, rgba(255,255,255,.25) 0%,transparent 100%),
    radial-gradient(1.5px 1.5px at 45% 38%, rgba(180,246,251,.35) 0%,transparent 100%),
    radial-gradient(1px 1px at 63% 92%, rgba(255,255,255,.20) 0%,transparent 100%);
}

.lock-card {
  position: relative;
  background: rgba(1,12,28,0.92);
  border: 1px solid rgba(0,200,255,0.22);
  border-radius: 20px;
  padding: 48px 44px 40px;
  width: min(420px, 92vw);
  display: flex; flex-direction: column; align-items: center; gap: 0;
  box-shadow: 0 0 80px rgba(0,100,220,0.25), 0 0 160px rgba(0,60,160,0.12), inset 0 0 40px rgba(0,40,120,0.14);
}
/* corner ticks */
.lock-card::before, .lock-card::after {
  content:''; position:absolute; width:16px; height:16px;
  border-color:rgba(0,200,255,.55); border-style:solid;
}
.lock-card::before { top:8px; left:8px; border-width:2px 0 0 2px; }
.lock-card::after  { bottom:8px; right:8px; border-width:0 2px 2px 0; }

.lock-logo {
  margin-bottom: 8px;
}
.lock-logo svg { width:64px; height:64px; }

.lock-title {
  font-size: 13px; letter-spacing:.35em; text-transform:uppercase;
  color: rgba(180,246,251,0.90); margin-bottom: 4px;
  text-shadow: 0 0 14px rgba(0,220,255,0.55);
}
.lock-subtitle {
  font-size: 10px; letter-spacing:.20em; text-transform:uppercase;
  color: rgba(0,180,255,0.42); margin-bottom: 36px;
}

/* ── Method tabs ── */
.lock-tabs {
  display: flex; gap: 10px; margin-bottom: 32px;
}
.lock-tab {
  padding: 8px 16px; border-radius: 6px; cursor: pointer;
  font-family: 'Courier New', monospace; font-size: 10px;
  letter-spacing:.18em; text-transform:uppercase;
  border: 1px solid rgba(0,160,255,.22);
  background: rgba(0,20,50,.40);
  color: rgba(0,180,255,.55);
  transition: all .2s;
  display: flex; align-items:center; gap:6px;
}
.lock-tab:hover { border-color:rgba(0,200,255,.50); color:rgba(0,220,255,.85); background:rgba(0,40,100,.35); }
.lock-tab.active {
  border-color:rgba(0,220,255,.70); color:rgba(180,246,251,.95);
  background:rgba(0,60,140,.40); box-shadow:0 0 12px rgba(0,180,255,.22);
}

/* ── Panels ── */
.lock-panel { width:100%; display:none; flex-direction:column; align-items:center; gap:0; }
.lock-panel.active { display:flex; }

/* ── Fingerprint ── */
.fp-ring {
  width: 120px; height: 120px; border-radius:50%;
  border: 2px solid rgba(0,200,255,.30);
  display:flex; align-items:center; justify-content:center;
  position:relative; cursor:pointer; margin-bottom:20px;
  transition: border-color .3s;
}
.fp-ring:hover { border-color:rgba(0,220,255,.60); }
.fp-ring.scanning { border-color:rgba(0,220,255,.90); animation:fpSpin 1.5s linear infinite; }
.fp-ring.success  { border-color:rgba(0,255,160,.80); animation:fpPulse 0.5s ease forwards; }
.fp-ring.fail     { border-color:rgba(255,60,60,.80);  animation:fpShake 0.4s ease; }
@keyframes fpSpin  { to{ filter:hue-rotate(360deg); } }
@keyframes fpPulse { 0%{transform:scale(1)} 50%{transform:scale(1.08)} 100%{transform:scale(1)} }
@keyframes fpShake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-8px)} 75%{transform:translateX(8px)} }

.fp-icon svg { width:52px; height:52px; }
.fp-scan-bar {
  position:absolute; left:10%; right:10%; height:2px; top:20%;
  background:linear-gradient(90deg,transparent,rgba(0,220,255,0.9),transparent);
  border-radius:1px; display:none;
  animation:fpBar 1.2s ease-in-out infinite;
}
.fp-ring.scanning .fp-scan-bar { display:block; }
@keyframes fpBar { 0%{top:15%} 100%{top:82%} }

.fp-outer-ring {
  position:absolute; inset:-8px; border-radius:50%;
  border:1px dashed rgba(0,180,255,.20);
  animation:fpRotate 4s linear infinite;
}
@keyframes fpRotate { to{transform:rotate(360deg)} }

/* ── Face scan ── */
.face-frame {
  width:180px; height:160px; position:relative;
  margin-bottom: 18px; border-radius:12px; overflow:hidden;
  border:1px solid rgba(0,200,255,.25);
  background:#000;
}
.face-frame video { width:100%; height:100%; object-fit:cover; display:block; }
.face-overlay {
  position:absolute; inset:0; pointer-events:none;
}
.face-overlay svg { width:100%; height:100%; }
.face-scan-line {
  position:absolute; left:0; right:0; height:2px;
  background:linear-gradient(90deg,transparent,rgba(0,220,255,0.85),transparent);
  animation:faceScan 2s ease-in-out infinite; display:none;
}
.face-scanning .face-scan-line { display:block; }
@keyframes faceScan { 0%{top:0%} 100%{top:100%} }
.face-status {
  font-size:10px; letter-spacing:.18em; text-transform:uppercase;
  color:rgba(0,180,255,.60); margin-bottom:18px;
}

/* ── PIN pad ── */
.pin-dots {
  display:flex; gap:12px; margin-bottom:28px;
}
.pin-dot {
  width:14px; height:14px; border-radius:50%;
  border:2px solid rgba(0,200,255,.40);
  background:transparent; transition:background .2s, border-color .2s;
}
.pin-dot.filled { background:rgba(0,200,255,.85); border-color:rgba(0,220,255,.90); box-shadow:0 0 8px rgba(0,200,255,.55); }

.pin-grid {
  display:grid; grid-template-columns:repeat(3,1fr); gap:8px; width:234px;
  margin-bottom:16px;
}
.pin-btn {
  height:58px; border-radius:8px; cursor:pointer;
  background:rgba(0,20,50,.50); border:1px solid rgba(0,160,255,.20);
  font-family:'Courier New',monospace;
  color:rgba(180,246,251,.90); transition:all .15s;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:2px; padding:6px 4px;
  user-select:none;
}
.pin-btn:hover { background:rgba(0,60,140,.50); border-color:rgba(0,200,255,.50); box-shadow:0 0 12px rgba(0,180,255,.20); }
.pin-btn:active { transform:scale(0.93); background:rgba(0,80,180,.55); }
.pin-btn.del  { color:rgba(255,120,120,.70); }
.pin-btn.del:hover { border-color:rgba(255,80,80,.40); color:rgba(255,140,140,.90); }
.pin-btn.pin-clr { color:rgba(0,180,255,.60); }
.pin-num {
  font-size:18px; font-weight:bold; line-height:1;
  color:inherit;
}
.pin-alpha {
  font-size:7.5px; letter-spacing:.18em; font-weight:500;
  color:rgba(100,210,240,.48); line-height:1; text-transform:uppercase;
}

.lock-msg {
  font-size:10px; letter-spacing:.18em; text-transform:uppercase;
  min-height:18px; margin-top:6px;
  transition: color .2s;
}
.lock-msg.ok   { color:rgba(0,255,160,.80); }
.lock-msg.err  { color:rgba(255,80,80,.80); animation:fpShake .3s ease; }
.lock-msg.info { color:rgba(0,180,255,.60); }

.lock-btn-row { display:flex; gap:12px; margin-top:18px; }
.lock-action-btn {
  padding:10px 28px; border-radius:8px; cursor:pointer;
  font-family:'Courier New',monospace; font-size:11px;
  letter-spacing:.18em; text-transform:uppercase;
  border:1px solid rgba(0,180,255,.35); background:rgba(0,40,100,.38);
  color:rgba(180,246,251,.90); transition:all .2s;
}
.lock-action-btn:hover { background:rgba(0,80,180,.50); border-color:rgba(0,220,255,.65); box-shadow:0 0 14px rgba(0,180,255,.25); }


/* ════════════════════════════════════════════════════════
   DATE & TIME CLOCK — right side, between earth & chat
   ════════════════════════════════════════════════════════ */

/* ── DATE & TIME — no box, centred between earth & chat widgets ──
   14" 1920×1080:
     earth  top:28px + height:420px  → bottom edge = 448px
     chat   bottom:28px + height:36vh(388px) → top edge = 664px
     gap centre = (448+664)/2 = 556px
   Clock renders ~24px tall, so top = 556 - 12 = 544px
── */
#dimpl-clock {
  position: fixed;
  right: clamp(16px, 1.6vw, 28px);
  top: calc(
    clamp(16px,1.6vw,28px) + clamp(280px,22vw,420px) +
    (100vh - clamp(16px,1.6vw,28px) - clamp(280px,22vw,420px) - clamp(16px,1.6vw,28px) - clamp(340px,36vh,520px) - clamp(16px,1.6vw,28px) - clamp(280px,22vw,420px)) * 0.5
  );
  width: clamp(280px,22vw,420px);
  display: none;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  pointer-events: none;
  font-family: 'Courier New', monospace;
  z-index: 9999;
}
body.dimpl-open #dimpl-clock { display: flex !important; }

#clock-time-line {
  font-size: 11px;
  font-weight: bold;
  letter-spacing: 0.22em;
  color: rgba(180,246,251,0.62);
  text-shadow: 0 0 8px rgba(0,200,255,0.25);
  white-space: nowrap;
}
#clock-colon {
  display: inline-block;
  animation: colonBlink 1s step-end infinite;
}
@keyframes colonBlink { 0%,100%{opacity:1} 50%{opacity:0.1} }

#clock-date-line {
  font-size: 9px;
  letter-spacing: 0.26em;
  text-transform: uppercase;
  color: rgba(0,175,220,0.36);
  white-space: nowrap;
}

</style>
