<!-- ═══════════════════════════════════════════════════════
     THREE.JS PARTICLE SPHERE  (bottom-left widget)
     Deferred: runs only after bubble is first opened
     ═══════════════════════════════════════════════════════ -->
<script type="module">
  import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.146.0/build/three.module.js';

  let sphereInitDone = false;

  function initSphere() {
    if (sphereInitDone) return;
    sphereInitDone = true;

  const container = document.getElementById('sphereContainer');
  // Force layout so clientWidth/Height are real
  // Get real size — read from parent .sphere-widget computed dimensions
  const widgetEl = container.closest('.sphere-widget') || container.parentElement;
  const cs = window.getComputedStyle(widgetEl);
  const W = parseFloat(cs.width)  || container.offsetWidth  || 320;
  const H = parseFloat(cs.height) || container.offsetHeight || 320;
  container.style.width  = W + 'px';
  container.style.height = H + 'px';

  const scene    = new THREE.Scene();
  const camera   = new THREE.PerspectiveCamera(60, W/H, 0.1, 100);
  camera.position.z = 2.6;

  const renderer = new THREE.WebGLRenderer({ antialias:true, alpha:true });
  renderer.setPixelRatio(window.devicePixelRatio);
  renderer.setSize(W, H);
  renderer.setClearColor(0x000000, 0);
  container.appendChild(renderer.domElement);

  /* colour palette: deep navy → electric cyan */
  const cStart = new THREE.Color(0x003080);
  const cEnd   = new THREE.Color(0x00EEFF);
  const N = 120000;
  const pos = new Float32Array(N*3), base = new Float32Array(N*3),
        nrm = new Float32Array(N*3), bCol= new Float32Array(N*3),
        phi = new Float32Array(N);

  for(let i=0;i<N;i++){
    const u=Math.random(), v=Math.random();
    const th=2*Math.PI*u, ph=Math.acos(2*v-1);
    const x=Math.sin(ph)*Math.cos(th)*0.55, y=Math.sin(ph)*Math.sin(th)*0.55, z=Math.cos(ph)*0.55;
    const idx=i*3;
    base.set([x,y,z],idx); nrm.set([x/0.55,y/0.55,z/0.55],idx); pos.set([x,y,z],idx);
    const t=(z/0.55+1)*0.5;
    const c=cStart.clone().lerp(cEnd,t);
    bCol.set([c.r,c.g,c.b],idx);
    phi[i]=Math.random()*Math.PI*2;
  }

  const geo = new THREE.BufferGeometry();
  geo.setAttribute('position', new THREE.BufferAttribute(pos,3));
  geo.setAttribute('color',    new THREE.BufferAttribute(bCol.slice(),3));

  const mat = new THREE.PointsMaterial({
    size:0.013, vertexColors:true, transparent:true, opacity:1.0, depthWrite:false,
    sizeAttenuation:true
  });
  const mesh = new THREE.Points(geo, mat);
  scene.add(mesh);

  const ray=new THREE.Raycaster(), mouse=new THREE.Vector2();
  const baseRot=0.0035, minRot=0.0010;
  let rotSpd=baseRot, smoothF=0, time=0;

  /* listen for mouse on the widget element */
  container.addEventListener('mousemove',e=>{
    const rect = container.getBoundingClientRect();
    mouse.x = ((e.clientX-rect.left)/rect.width)*2-1;
    mouse.y = -((e.clientY-rect.top)/rect.height)*2+1;
  });

  /* audio analyser */
  let analyser, dataArr;
  (async()=>{
    try{
      const stream = await navigator.mediaDevices.getUserMedia({audio:true});
      const actx = new (window.AudioContext||window.webkitAudioContext)();
      const src = actx.createMediaStreamSource(stream);
      analyser = actx.createAnalyser(); analyser.fftSize=2048;
      src.connect(analyser);
      dataArr = new Uint8Array(analyser.fftSize);

      /* speech recognition → route to Claude via chat widget */
      const SR = window.SpeechRecognition||window.webkitSpeechRecognition;
      if(SR){
        const rec = new SR();
        rec.continuous=true; rec.interimResults=false; rec.lang='en-US';
        rec.onend=()=>{ try{ rec.start(); }catch(e){} };
        rec.onresult=(e)=>{
          const msg=e.results[e.results.length-1][0].transcript.trim();
          if(!msg) return;
          showChat('🎙 ' + msg);
          // Route through main Claude chat engine
          if(window._dimplSend) window._dimplSend(msg); // route to local backend
        };
        rec.start();
      }
    }catch(e){console.warn('Mic unavailable',e);}
  })();

  function showChat(txt){
    const cb=document.getElementById('chatBox');
    cb.textContent=txt; cb.style.opacity=1;
    setTimeout(()=>cb.style.opacity=0, 4000);
  }

  function animate(){
    requestAnimationFrame(animate);
    time+=0.022;

    let raw=0;
    if(analyser){
      analyser.getByteTimeDomainData(dataArr);
      let s=0; for(const v of dataArr){const d=(v-128)/128;s+=d*d;}
      raw=Math.sqrt(s/dataArr.length)*1.3;
      raw=THREE.MathUtils.clamp(raw,0,1);
    }
    /* fast attack (0.72) when sound rises, fast decay (0.55) when it falls */
    const lerpRate = raw > smoothF ? 0.72 : 0.55;
    smoothF+=(raw-smoothF)*lerpRate;
    const disp=Math.min(0.18+smoothF*0.82,0.5);

    const posArr=geo.attributes.position.array;
    for(let i=0;i<N;i++){
      const idx=i*3, off=disp*Math.sin(time+phi[i]);
      posArr[idx]  =base[idx]  +nrm[idx]  *off;
      posArr[idx+1]=base[idx+1]+nrm[idx+1]*off;
      posArr[idx+2]=base[idx+2]+nrm[idx+2]*off;
    }
    geo.attributes.position.needsUpdate=true;
    mesh.rotation.x+=smoothF*0.0004;
    mesh.rotation.z+=smoothF*0.0002;

    /* hover highlight */
    ray.setFromCamera(mouse,camera);
    const hits=ray.intersectObject(mesh);
    const colArr=geo.attributes.color.array;
    if(hits.length>0){
      const hp=hits[0].point, r2=0.18*0.18, wm=mesh.matrixWorld;
      for(let i=0;i<N;i++){
        const idx=i*3;
        const wp=new THREE.Vector3(posArr[idx],posArr[idx+1],posArr[idx+2]).applyMatrix4(wm);
        const dx=wp.x-hp.x, dy=wp.y-hp.y, dz=wp.z-hp.z;
        if(dx*dx+dy*dy+dz*dz<r2){colArr[idx]=1;colArr[idx+1]=0.3;colArr[idx+2]=0.6;}
        else{colArr[idx]=bCol[idx];colArr[idx+1]=bCol[idx+1];colArr[idx+2]=bCol[idx+2];}
      }
      rotSpd=Math.max(rotSpd*0.92,minRot);
    } else {
      for(let i=0;i<colArr.length;i++) colArr[i]=bCol[i];
      rotSpd=baseRot;
    }
    geo.attributes.color.needsUpdate=true;

    mesh.rotation.y+=rotSpd;
    renderer.render(scene,camera);
  }
  animate();

  // Handle window resize
  window.addEventListener('resize', () => {
    const nW = container.offsetWidth, nH = container.offsetHeight;
    if(nW > 0 && nH > 0){
      camera.aspect = nW/nH;
      camera.updateProjectionMatrix();
      renderer.setSize(nW, nH);
    }
  });

  } // end initSphere

  // Listen for the body getting dimpl-open class (triggered by bubble click)
  const _obs = new MutationObserver(() => {
    if (document.body.classList.contains('dimpl-open')) {
      // Wait for display:flex/grid to take effect, then init
      requestAnimationFrame(() => setTimeout(initSphere, 100));
    }
  });
  _obs.observe(document.body, { attributes: true, attributeFilter: ['class'] });
</script>



