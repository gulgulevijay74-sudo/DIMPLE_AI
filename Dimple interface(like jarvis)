<script>
/* ══════════════════════════════════════════════════════
   DIMPL BUBBLE — drag, open/close, AI auto-start
   ══════════════════════════════════════════════════════ */
(function(){
  const bubble  = document.getElementById('dimpl-bubble');
  const app     = document.getElementById('dimpl-app');
  const closeBtn= document.getElementById('dimpl-close');

  /* ── Dragging ── */
  let dragging=false, dragOX=0, dragOY=0, moved=false;

  bubble.addEventListener('mousedown', e=>{
    dragging=true; moved=false;
    dragOX = e.clientX - bubble.getBoundingClientRect().left;
    dragOY = e.clientY - bubble.getBoundingClientRect().top;
    bubble.classList.add('dragging');
    e.preventDefault();
  });
  bubble.addEventListener('touchstart', e=>{
    dragging=true; moved=false;
    const t=e.touches[0];
    dragOX = t.clientX - bubble.getBoundingClientRect().left;
    dragOY = t.clientY - bubble.getBoundingClientRect().top;
    bubble.classList.add('dragging');
  }, {passive:true});

  function onMove(cx,cy){
    if(!dragging) return;
    moved=true;
    let nx = cx - dragOX;
    let ny = cy - dragOY;
    const maxX = window.innerWidth  - bubble.offsetWidth;
    const maxY = window.innerHeight - bubble.offsetHeight;
    nx = Math.max(0, Math.min(nx, maxX));
    ny = Math.max(0, Math.min(ny, maxY));
    bubble.style.left   = nx+'px';
    bubble.style.top    = ny+'px';
    bubble.style.right  = 'auto';
    bubble.style.bottom = 'auto';
    // update transform origin so overlay expands from bubble position
    const cx2 = nx + bubble.offsetWidth/2;
    const cy2 = ny + bubble.offsetHeight/2;
    app.style.setProperty('--bubble-origin', cx2+'px '+cy2+'px');
    document.documentElement.style.setProperty('--bubble-origin', cx2+'px '+cy2+'px');
  }

  document.addEventListener('mousemove', e=> onMove(e.clientX, e.clientY));
  document.addEventListener('touchmove', e=>{ const t=e.touches[0]; onMove(t.clientX,t.clientY); }, {passive:true});

  function stopDrag(){
    if(!dragging) return;
    dragging=false;
    bubble.classList.remove('dragging');
  }
  document.addEventListener('mouseup',  stopDrag);
  document.addEventListener('touchend', stopDrag);

  /* ══ STATE MACHINE ══════════════════════════════════════════
     State 1: BUBBLE  — only bubble visible
     State 2: LOCK    — lock screen (only on first open per session)
     State 3: APP     — main UI open

     SESSION LOGIC:
       • sessionStorage key "dimpl_unlocked" persists while the
         browser tab/window stays open (survives page refresh).
       • It is CLEARED automatically when:
           - Browser/tab is closed
           - Laptop sleeps / screen locks  (visibilitychange hidden
             held for > SLEEP_THRESHOLD ms)
           - User explicitly signs out
       • Result: lock shows ONCE per "session" (wake cycle).
     ═══════════════════════════════════════════════════════════ */

  const SESSION_KEY     = 'dimpl_unlocked';   // sessionStorage key
  const SLEEP_THRESHOLD = 8000;               // ms hidden = treat as sleep/lock

  let aiStarted  = false;
  let appState   = 'bubble';
  let hiddenAt   = null;   // timestamp when page became hidden

  /* ── Session helpers ── */
  function isUnlocked(){
    return sessionStorage.getItem(SESSION_KEY) === '1';
  }
  function setUnlocked(){
    sessionStorage.setItem(SESSION_KEY, '1');
  }
  function clearUnlocked(){
    sessionStorage.removeItem(SESSION_KEY);
    if(window._dimplResetLock) window._dimplResetLock();
  }

  /* ── Detect sleep / screen lock ──
     When the laptop sleeps or the screen locks, the browser fires
     visibilitychange with document.hidden = true.
     If it stays hidden for > SLEEP_THRESHOLD ms we treat it as a
     sleep event and require auth again next open.              ── */
  document.addEventListener('visibilitychange', () => {
    if(document.hidden){
      hiddenAt = Date.now();
    } else {
      if(hiddenAt !== null){
        const elapsed = Date.now() - hiddenAt;
        if(elapsed > SLEEP_THRESHOLD){
          // System woke from sleep / screen unlock → require auth
          clearUnlocked();
          // If app is open, push back to bubble so lock shows next click
          if(appState === 'app') window._dimplGoBubble();
        }
        hiddenAt = null;
      }
    }
  });

  /* ── Also clear on tab/window close ── */
  window.addEventListener('pagehide', () => clearUnlocked());

  /* ── State transitions ── */
  window._dimplGoApp = function goApp(){
    appState = 'app';
    setUnlocked();
    bubble.style.display = 'none';
    document.body.classList.add('dimpl-open');
    if(!aiStarted){ if(window._dimplStartAI) window._dimplStartAI(); aiStarted=true; }
  };

  window._dimplGoLock = function goLock(){
    appState = 'lock';
    bubble.style.display = 'none';
    const lock = document.getElementById('dimpl-lock');
    lock.classList.remove('lock-hidden');
    lock.classList.add('lock-visible');
  };

  window._dimplGoBubble = function goBubble(){
    appState = 'bubble';
    document.body.classList.remove('dimpl-open');
    bubble.style.display = 'flex';
    bubble.classList.add('ai-active');
    const lock = document.getElementById('dimpl-lock');
    lock.style.display = 'none';
    lock.classList.remove('lock-visible','lock-hidden');
  };

  /* ── Bubble click ──
     • Already unlocked this session → go straight to app
     • Not yet unlocked            → show lock screen first     ── */
  bubble.addEventListener('click', e=>{
    if(moved) return;
    if(appState !== 'bubble') return;
    if(isUnlocked()){
      window._dimplGoApp();          // skip lock — already verified
    } else {
      window._dimplGoLock();         // first open — show security screen
    }
  });
  bubble.addEventListener('touchend', e=>{
    if(moved) return;
    if(appState !== 'bubble') return;
    if(isUnlocked()){
      window._dimplGoApp();
    } else {
      window._dimplGoLock();
    }
  });

  // Close button → back to bubble (NO lock reset — stays unlocked)
  closeBtn.addEventListener('click', ()=>{
    window._dimplGoBubble();
    // deliberately do NOT call clearUnlocked() here
    // so next bubble click reopens app directly
  });

  // ESC → back to bubble
  document.addEventListener('keydown', e=>{
    if(e.key==='Escape' && appState === 'app') window._dimplGoBubble();
  });

  /* ── AI Start: kick off speech recognition & mic ── */
  window._dimplStartAI = function startAI(){
    // trigger mic permission warmup silently
    if(navigator.mediaDevices && navigator.mediaDevices.getUserMedia){
      navigator.mediaDevices.getUserMedia({audio:true}).then(s=>{
        // permission granted — Three.js sphere will connect its own analyser
        s.getTracks().forEach(t=>t.stop());
      }).catch(()=>{});
    }
    // auto-focus chat input
    setTimeout(()=>{
      const inp = document.getElementById('chatInput');
      if(inp) inp.focus();
    }, 380);
    // show "AI started" message in chat
    setTimeout(()=>{
      const msgs = document.getElementById('chatMessages');
      if(!msgs) return;
      const wrap = document.createElement('div');
      wrap.className='chat-msg bot';
      const b=document.createElement('div'); b.className='chat-bubble';
      b.textContent='⚡ D.I.M.P.L engaged. Neural field active. Awaiting input.';
      const t=document.createElement('span'); t.className='chat-time';
      const d=new Date();
      t.textContent=d.getHours().toString().padStart(2,'0')+':'+d.getMinutes().toString().padStart(2,'0')+':'+d.getSeconds().toString().padStart(2,'0');
      wrap.appendChild(b); wrap.appendChild(t);
      msgs.appendChild(wrap);
      msgs.scrollTop=msgs.scrollHeight;
    }, 500);
  }

  // Set initial transform origin (bottom-right default)
  app.style.setProperty('--bubble-origin','calc(100% - 64px) calc(100% - 64px)');
})();
</script>

<script>
/* ════════════════════════════════════════════════════════
   DIMPL SECURITY LOCK — Fingerprint / Face ID / PIN
   ════════════════════════════════════════════════════════ */
(function(){
  const lockEl = document.getElementById('dimpl-lock');
  const bubble = document.getElementById('dimpl-bubble');

  /* ── Unlock: fade out lock → open main app (State 2 → State 3) ── */
  function unlock(){
    lockEl.classList.remove('lock-visible');
    lockEl.classList.add('lock-hidden');
    setTimeout(function(){
      lockEl.style.display = 'none';
      lockEl.classList.remove('lock-hidden');
      if(window._dimplGoApp) window._dimplGoApp();
      else {
        document.body.classList.add('dimpl-open');
        if(window._dimplStartAI) window._dimplStartAI();
      }
    }, 460);
  }

  /* ── No bubble listener here — state machine handles it ── */

  window._dimplResetLock = function resetAll(){
    resetFingerprint();
    pinInput = '';
    updatePinDots();
    pinMsg.className = 'lock-msg info';
    pinMsg.textContent = 'Enter PIN';
    pinLocked = false;
  }

  /* ══ TAB SWITCHING ══ */
  document.querySelectorAll('.lock-tab').forEach(function(tab){
    tab.addEventListener('click', function(){
      document.querySelectorAll('.lock-tab').forEach(function(t){ t.classList.remove('active'); });
      document.querySelectorAll('.lock-panel').forEach(function(p){ p.classList.remove('active'); });
      tab.classList.add('active');
      document.getElementById('lp-' + tab.dataset.tab).classList.add('active');
      if(tab.dataset.tab === 'face') initFacePanel();
      else stopFaceStream();
    });
  });

  /* ══ FINGERPRINT — WebAuthn ══ */
  var fpRing    = document.getElementById('fpRing');
  var fpMsg     = document.getElementById('fpMsg');
  var fpScanBtn = document.getElementById('fpScanBtn');
  var fpRunning = false;

  async function doFingerprint(){
    if(fpRunning) return;
    fpRunning = true;
    fpMsg.className = 'lock-msg info';
    fpRing.classList.remove('success','fail');
    fpRing.classList.add('scanning');
    fpScanBtn.disabled = true;
    fpScanBtn.textContent = 'Scanning…';

    if(!window.PublicKeyCredential){
      showFpFail('WebAuthn not supported · Use PIN');
      return;
    }

    try {
      var available = await PublicKeyCredential.isUserVerifyingPlatformAuthenticatorAvailable();
      if(!available){
        showFpFail('No biometric sensor found · Use PIN');
        return;
      }
      fpMsg.textContent = 'Touch your fingerprint sensor…';
      var chal = new Uint8Array(32);
      crypto.getRandomValues(chal);
      var cred = await navigator.credentials.get({
        publicKey:{
          challenge: chal,
          timeout: 60000,
          userVerification: 'required',
          rpId: location.hostname || 'localhost'
        }
      });
      if(cred){
        fpRing.classList.remove('scanning');
        fpRing.classList.add('success');
        fpMsg.className = 'lock-msg ok';
        fpMsg.textContent = '✓ Biometric Verified · Welcome, Vaibhav';
        fpRunning = false;
        setTimeout(unlock, 900);
      }
    } catch(e){
      if(e.name === 'NotAllowedError'){
        showFpFail('Cancelled · Use PIN');
      } else if(e.name === 'InvalidStateError' || e.name === 'NotSupportedError'){
        showFpFail('No credential registered · Use PIN');
      } else {
        showFpFail('Error: ' + (e.message||e.name).slice(0,36));
      }
    }
  }

  function showFpFail(msg){
    fpRunning = false;
    fpRing.classList.remove('scanning');
    fpRing.classList.add('fail');
    fpMsg.className = 'lock-msg err';
    fpMsg.textContent = msg;
    setTimeout(resetFingerprint, 2500);
  }

  function resetFingerprint(){
    fpRunning = false;
    fpRing.classList.remove('scanning','success','fail');
    fpMsg.className = 'lock-msg info';
    fpMsg.textContent = 'Touch to scan fingerprint';
    fpScanBtn.disabled = false;
    fpScanBtn.textContent = '⊙ Scan Now';
  }

  fpScanBtn.addEventListener('click', doFingerprint);
  fpRing.addEventListener('click', doFingerprint);

  /* ══ FACE ID ══ */
  var faceVideo    = document.getElementById('faceVideo');
  var faceFrame    = document.getElementById('faceFrame');
  var faceMsg      = document.getElementById('faceMsg');
  var faceStartBtn = document.getElementById('faceStartBtn');
  var faceStream   = null;
  var faceScanning = false;

  async function initFacePanel(){
    if(faceStream) return;
    faceMsg.className = 'lock-msg info';
    faceMsg.textContent = 'Starting camera…';
    try{
      faceStream = await navigator.mediaDevices.getUserMedia({video:{facingMode:'user'},audio:false});
      faceVideo.srcObject = faceStream;
      faceMsg.textContent = 'Position face in frame';
    } catch(e){
      faceMsg.className = 'lock-msg err';
      faceMsg.textContent = 'Camera unavailable · Use PIN';
    }
  }

  function stopFaceStream(){
    if(faceStream){ faceStream.getTracks().forEach(function(t){ t.stop(); }); faceStream = null; }
    faceVideo.srcObject = null;
    faceScanning = false;
    faceFrame.classList.remove('face-scanning');
  }

  async function doFaceScan(){
    if(!faceStream) await initFacePanel();
    if(!faceStream || faceScanning) return;
    faceScanning = true;
    faceStartBtn.disabled = true;
    faceFrame.classList.add('face-scanning');
    faceMsg.className = 'lock-msg info';
    var steps = [
      [700,  'Detecting face…'],
      [1100, 'Mapping depth points…'],
      [900,  'Verifying identity…'],
      [700,  'Cross-referencing…']
    ];
    for(var i=0; i<steps.length; i++){
      await new Promise(function(r){ setTimeout(r, steps[i][0]); });
      faceMsg.textContent = steps[i][1];
    }
    faceFrame.classList.remove('face-scanning');
    faceMsg.className = 'lock-msg ok';
    faceMsg.textContent = '✓ Face Verified · Welcome, Vaibhav';
    stopFaceStream();
    setTimeout(unlock, 800);
  }

  faceStartBtn.addEventListener('click', doFaceScan);

  /* ══ PIN PAD ══ */
  var pinGrid     = document.getElementById('pinGrid');
  var pinMsg      = document.getElementById('pinMsg');
  var pinDotsWrap = document.getElementById('pinDots');
  var PIN_PRIMARY  = '8087';
  var PIN_FALLBACK = '8242428'; // vaibhav T9
  var MAX_LEN      = 7;
  var pinInput    = '';
  var pinLocked   = false;
  var pinAttempts = 0;
  var MAX_ATTEMPTS = 5;

  function updatePinDots(){
    var expected = (pinInput.length > 4) ? 7 : 4;
    pinDotsWrap.innerHTML = '';
    for(var i=0; i<expected; i++){
      var d = document.createElement('div');
      d.className = 'pin-dot' + (i < pinInput.length ? ' filled' : '');
      pinDotsWrap.appendChild(d);
    }
  }

  function getDots(){ return pinDotsWrap.querySelectorAll('.pin-dot'); }

  function flashDots(type){
    var color = type === 'ok' ? 'rgba(0,255,160,.8)' : 'rgba(255,60,60,.8)';
    var bg    = type === 'ok' ? 'rgba(0,255,160,.6)' : 'rgba(255,60,60,.6)';
    getDots().forEach(function(d){
      d.style.borderColor = color;
      d.style.background  = bg;
    });
    setTimeout(function(){
      getDots().forEach(function(d){ d.style.borderColor=''; d.style.background=''; });
    }, 500);
  }

  function checkPin(){
    var isPrimary  = (pinInput === PIN_PRIMARY);
    var isFallback = (pinInput === PIN_FALLBACK);

    if(isPrimary || isFallback){
      pinLocked = true;
      flashDots('ok');
      pinMsg.className = 'lock-msg ok';
      pinMsg.textContent = isFallback ? '✓ Welcome, Vaibhav' : '✓ Access Granted';
      setTimeout(unlock, 700);
      return;
    }

    // At 4 digits: if it's a valid prefix of fallback, let user continue
    if(pinInput.length === 4 && PIN_FALLBACK.startsWith(pinInput)){
      pinMsg.className = 'lock-msg info';
      pinMsg.textContent = 'Continue for word-PIN…';
      return;
    }

    // Wrong PIN
    pinAttempts++;
    flashDots('err');
    pinMsg.className = 'lock-msg err';

    if(pinAttempts >= MAX_ATTEMPTS){
      pinMsg.textContent = '⚠ Too many attempts · Try fingerprint';
      pinLocked = true;
      setTimeout(function(){
        pinLocked = false; pinAttempts = 0;
        pinInput = ''; updatePinDots();
        pinMsg.className = 'lock-msg info';
        pinMsg.textContent = 'Enter PIN';
      }, 10000);
    } else {
      pinMsg.textContent = '✗ Wrong PIN · ' + (MAX_ATTEMPTS - pinAttempts) + ' attempts left';
      setTimeout(function(){
        pinInput = ''; updatePinDots(); pinLocked = false;
        pinMsg.className = 'lock-msg info';
        pinMsg.textContent = 'Enter PIN';
      }, 1000);
    }
  }

  pinGrid.addEventListener('click', function(e){
    var btn = e.target.closest('.pin-btn');
    if(!btn || pinLocked) return;
    var d = btn.dataset.d;

    if(d === 'del'){
      pinInput = pinInput.slice(0,-1);
      pinMsg.className = 'lock-msg info';
      pinMsg.textContent = 'Enter PIN';
    } else if(d === '*'){
      pinInput = '';
      pinMsg.className = 'lock-msg info';
      pinMsg.textContent = 'Enter PIN';
    } else if(pinInput.length < MAX_LEN){
      pinInput += d;
    }
    updatePinDots();

    if(pinInput.length === 4 || pinInput.length === 7){
      checkPin();
    }
  });

  /* ── Keyboard support ── */
  document.addEventListener('keydown', function(e){
    if(lockEl.style.display === 'none') return;
    var activeTab = document.querySelector('.lock-tab.active');
    if(!activeTab || activeTab.dataset.tab !== 'pin') return;
    if(e.key >= '0' && e.key <= '9'){
      var btn = pinGrid.querySelector('[data-d="'+e.key+'"]');
      if(btn) btn.click();
    } else if(e.key === 'Backspace'){
      pinGrid.querySelector('[data-d="del"]').click();
    } else if(e.key === 'Escape'){
      pinGrid.querySelector('[data-d="*"]').click();
    }
  });

  // Init dots on load
  updatePinDots();

})();
</script>

<script>
/* ══ LIVE CLOCK ══ */
(function(){
  const DAYS   = ['SUN','MON','TUE','WED','THU','FRI','SAT'];
  const MONTHS = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  function pad(n){ return String(n).padStart(2,'0'); }

  const clock = document.getElementById('dimpl-clock');

  // Build DOM once
  const timeLine = document.createElement('div');
  timeLine.id = 'clock-time-line';
  const dateLine = document.createElement('div');
  dateLine.id = 'clock-date-line';
  clock.appendChild(timeLine);
  clock.appendChild(dateLine);

  function tick(){
    const now = new Date();
    const h   = now.getHours();
    const m   = now.getMinutes();
    const s   = now.getSeconds();
    const h12 = h % 12 || 12;
    const ampm = h < 12 ? 'AM' : 'PM';

    timeLine.innerHTML =
      pad(h12) +
      '<span id="clock-colon">:</span>' +
      pad(m) + ':' + pad(s) + ' ' + ampm;

    dateLine.textContent =
      DAYS[now.getDay()] + ' · ' +
      pad(now.getDate()) + ' ' + MONTHS[now.getMonth()] + ' ' + now.getFullYear();
  }

  tick();
  setInterval(tick, 1000);
})();
</script>

