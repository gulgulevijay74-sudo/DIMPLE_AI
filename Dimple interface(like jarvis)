<!-- ═══════════════════════════════════════════════════════
     D.I.M.P.L — LOCAL AI CHAT (talks to dimple_setup.py)
     ═══════════════════════════════════════════════════════ -->
<script>
(function(){
  const messages = document.getElementById('chatMessages');
  const input    = document.getElementById('chatInput');
  const sendBtn  = document.getElementById('chatSend');

  // Local backend endpoint — dimple_setup.py serves this
  const BACKEND = window.location.origin + '/chat';  // served by dimple_setup.py

  function timeNow(){
    const d=new Date();
    return d.getHours().toString().padStart(2,'0')+':'+d.getMinutes().toString().padStart(2,'0')+':'+d.getSeconds().toString().padStart(2,'0');
  }

  function addMsg(text, role){
    const wrap = document.createElement('div');
    wrap.className = 'chat-msg ' + role;
    const bub = document.createElement('div');
    bub.className = 'chat-bubble';
    bub.textContent = text;
    const time = document.createElement('span');
    time.className = 'chat-time';
    time.textContent = timeNow();
    wrap.appendChild(bub);
    wrap.appendChild(time);
    messages.appendChild(wrap);
    messages.scrollTop = messages.scrollHeight;
    return bub;
  }

  function showTyping(){
    const wrap = document.createElement('div');
    wrap.className = 'chat-msg bot'; wrap.id = 'typingIndicator';
    const bub = document.createElement('div');
    bub.className = 'chat-bubble'; bub.textContent = '· · ·';
    bub.style.letterSpacing='0.3em'; bub.style.opacity='0.6';
    wrap.appendChild(bub); messages.appendChild(wrap);
    messages.scrollTop = messages.scrollHeight;
  }
  function removeTyping(){ const t=document.getElementById('typingIndicator'); if(t) t.remove(); }

  async function sendToBackend(userText){
    showTyping();
    sendBtn.disabled = true;
    input.disabled   = true;

    try {
      const res = await fetch(BACKEND, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: userText })
      });
      const data = await res.json();
      removeTyping();
      const reply = data.reply || '⚠ No response from backend.';
      addMsg(reply, 'bot');
      // sphere overlay
      const cb = document.getElementById('chatBox');
      if(cb){ cb.textContent=reply; cb.style.opacity=1; setTimeout(()=>cb.style.opacity=0,5000); }
    } catch(err) {
      removeTyping();
      addMsg('⚠ Backend offline. Start dimple_setup.py first.', 'bot');
    }

    sendBtn.disabled = false;
    input.disabled   = false;
    input.focus();
  }

  function send(){
    const text = input.value.trim();
    if(!text) return;
    addMsg(text, 'user');
    input.value = '';
    sendToBackend(text);
  }

  window._dimplSend = function(text){
    if(!text || !text.trim()) return;
    addMsg(text, 'user');
    sendToBackend(text);
  };

  sendBtn.addEventListener('click', send);
  input.addEventListener('keydown', e=>{ if(e.key==='Enter' && !e.shiftKey) send(); });
})();
</script>

<script>
